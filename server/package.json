{
  "name": "cms-server",
  "version": "1.0.0",
  "description": "Complaint Management System - backend API",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node migrations/run.js",
    "seed": "node migrations/seed.js",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand --testPathPattern=tests/unit",
    "test:integration": "node tests/integration/helpers/dbGuard.js && jest --runInBand --testPathPattern=tests/integration"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 15000
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
