# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgres://cms_user:cms_password@localhost:5432/cms_db

# Test database - used by `npm run test:integration`
# Run `npm run migrate` against this DB once before running integration tests.
# Using a separate DB from cms_db keeps dev data safe when tests INSERT/DELETE rows.
TEST_DATABASE_URL=postgres://cms_user:cms_password@localhost:5432/cms_test_db

# Auth
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=8h

# CORS
CLIENT_ORIGIN=http://localhost:3000
